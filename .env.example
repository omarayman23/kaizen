# ── Contact form (Resend) ────────────────────────────────────────────
# Copy this file to ".env.local" for local dev, and add the same values in
# the Vercel dashboard (Project → Settings → Environment Variables) for prod.

# REQUIRED — your Resend API key. Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — overrides (sensible defaults are baked into api/contact.ts):
# Where contact-form submissions are delivered:
# OWNER_EMAIL=contract@kaizenpmconsulting.com
# Verified sender address (must be on a domain verified in Resend):
# FROM_EMAIL=Kaizen Project Management <contract@kaizenpmconsulting.com>
